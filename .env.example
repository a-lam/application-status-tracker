# Copy this file to .env and fill in all values before starting the server.
# The server will refuse to start if any required variable is missing.

# ─── Auth ──────────────────────────────────────────────────────────────────────
# Cryptographically random secret used to sign sessions.
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Session lifetime in whole hours. Defaults to 72 (3 days) if omitted.
SESSION_EXPIRY_HOURS=72

# ─── Google OAuth ──────────────────────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── GitHub OAuth ──────────────────────────────────────────────────────────────
# Create an OAuth App at https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─── Email (Resend) ────────────────────────────────────────────────────────────
# API key from https://resend.com/api-keys
RESEND_API_KEY=
# Sender address — must be on a domain verified in your Resend account
RESEND_FROM_EMAIL=

# ─── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string.
# Local dev example: postgresql://postgres:postgres@localhost:5432/app_db
DATABASE_URL=

# ─── URLs ──────────────────────────────────────────────────────────────────────
# The origin of your frontend (used for CORS and auth redirects).
# Local dev: http://localhost:5173
FRONTEND_URL=

# ─── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
